    OUTPUT RETAIN 64 minecraft:prismarine_slab TO EACH Crusher
    OUTPUT RETAIN 64 minecraft:prismarine_stairs TO EACH Crusher
    OUTPUT RETAIN 64 minecraft:prismarine_wall TO EACH Crusher
    OUTPUT RETAIN 64 minecraft:pumpkin_pie TO EACH Crusher
    OUTPUT RETAIN 64 minecraft:purpur_pillar TO EACH Crusher
    OUTPUT RETAIN 64 minecraft:quartz_block TO EACH Crusher
    OUTPUT RETAIN 64 minecraft:quartz_bricks TO EACH Crusher
    OUTPUT RETAIN 64 minecraft:quartz_pillar TO EACH Crusher
    OUTPUT RETAIN 64 minecraft:quartz_slab TO EACH Crusher
    OUTPUT RETAIN 64 minecraft:quartz_stairs TO EACH Crusher
    OUTPUT RETAIN 64 minecraft:rotten_flesh TO EACH Crusher
    OUTPUT RETAIN 64 minecraft:sea_pickle TO EACH Crusher
    OUTPUT RETAIN 64 minecraft:seagrass TO EACH Crusher
    OUTPUT RETAIN 64 minecraft:short_grass TO EACH Crusher
    OUTPUT RETAIN 64 minecraft:shroomlight TO EACH Crusher
    OUTPUT RETAIN 64 minecraft:small_dripleaf TO EACH Crusher
    OUTPUT RETAIN 64 minecraft:smooth_quartz TO EACH Crusher
    OUTPUT RETAIN 64 minecraft:soul_soil TO EACH Crusher
    OUTPUT RETAIN 64 minecraft:spore_blossom TO EACH Crusher
    OUTPUT RETAIN 64 minecraft:stone TO EACH Crusher
    OUTPUT RETAIN 64 minecraft:stone_bricks TO EACH Crusher
    OUTPUT RETAIN 64 minecraft:stone_slab TO EACH Crusher
    OUTPUT RETAIN 64 minecraft:stone_stairs TO EACH Crusher
    OUTPUT RETAIN 64 minecraft:tall_grass TO EACH Crusher
    OUTPUT RETAIN 64 minecraft:tuff TO EACH Crusher
    OUTPUT RETAIN 64 minecraft:tuff_brick_slab TO EACH Crusher
    OUTPUT RETAIN 64 minecraft:tuff_brick_stairs TO EACH Crusher
    OUTPUT RETAIN 64 minecraft:tuff_brick_wall TO EACH Crusher
    OUTPUT RETAIN 64 minecraft:tuff_bricks TO EACH Crusher
    OUTPUT RETAIN 64 minecraft:tuff_slab TO EACH Crusher
    OUTPUT RETAIN 64 minecraft:tuff_stairs TO EACH Crusher
    OUTPUT RETAIN 64 minecraft:tuff_wall TO EACH Crusher
    OUTPUT RETAIN 64 minecraft:warped_roots TO EACH Crusher
    OUTPUT RETAIN 64 minecraft:warped_wart_block TO EACH Crusher

    -- biomesoplenty sandstone family (compound recipes: base/chiseled/cut/smooth all -> sand)
    OUTPUT RETAIN 64 biomesoplenty:black_sandstone TO EACH Crusher
    OUTPUT RETAIN 64 biomesoplenty:chiseled_black_sandstone TO EACH Crusher
    OUTPUT RETAIN 64 biomesoplenty:cut_black_sandstone TO EACH Crusher
    OUTPUT RETAIN 64 biomesoplenty:smooth_black_sandstone TO EACH Crusher
    OUTPUT RETAIN 64 biomesoplenty:orange_sandstone TO EACH Crusher
    OUTPUT RETAIN 64 biomesoplenty:chiseled_orange_sandstone TO EACH Crusher
    OUTPUT RETAIN 64 biomesoplenty:cut_orange_sandstone TO EACH Crusher
    OUTPUT RETAIN 64 biomesoplenty:smooth_orange_sandstone TO EACH Crusher
    OUTPUT RETAIN 64 biomesoplenty:white_sandstone TO EACH Crusher
    OUTPUT RETAIN 64 biomesoplenty:chiseled_white_sandstone TO EACH Crusher
    OUTPUT RETAIN 64 biomesoplenty:cut_white_sandstone TO EACH Crusher
    OUTPUT RETAIN 64 biomesoplenty:smooth_white_sandstone TO EACH Crusher

    -- remaining compound recipes (mushrooms/fungi/vines/basalt -> bio_fuel or basalt)
    OUTPUT RETAIN 64 minecraft:brown_mushroom_block TO EACH Crusher
    OUTPUT RETAIN 64 minecraft:red_mushroom_block TO EACH Crusher
    OUTPUT RETAIN 64 minecraft:mushroom_stem TO EACH Crusher
    OUTPUT RETAIN 64 minecraft:crimson_fungus TO EACH Crusher
    OUTPUT RETAIN 64 minecraft:warped_fungus TO EACH Crusher
    OUTPUT RETAIN 64 minecraft:polished_basalt TO EACH Crusher
    OUTPUT RETAIN 64 minecraft:smooth_basalt TO EACH Crusher
    OUTPUT RETAIN 64 minecraft:vine TO EACH Crusher
    OUTPUT RETAIN 64 minecraft:twisting_vines TO EACH Crusher
    OUTPUT RETAIN 64 minecraft:weeping_vines TO EACH Crusher

    FORGET

    -- Drain finished items to storage (Crusher has a single output slot, same as Assembler)
    INPUT FROM EACH Crusher SLOTS 1
    OUTPUT TO EMPTY SLOTS IN Storage

END
